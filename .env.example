OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
PORT=3001

# --- Midnight Tier A (Phase 0+) ---
# Proof server: npm run midnight:up  |  check: npm run check:midnight
# Set true after deploy:midnight and funding wallet (preprod faucet)
MIDNIGHT_ENABLED=false
MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300
MIDNIGHT_NETWORK_ID=preprod

# Phase 1+ (after Compact compile)
MIDNIGHT_ZK_ARTIFACTS_PATH=contracts/managed/memory-access

# Phase 1+ (after contract deploy)
MIDNIGHT_CONTRACT_ADDRESS=
MIDNIGHT_WALLET_SEED=
MIDNIGHT_PRIVATE_STATE_PASSWORD=
MIDNIGHT_INDEXER_QUERY_URL=
MIDNIGHT_INDEXER_WS_URL=

# Deploy only — preprod sync often hangs (shielded/dust)
# MIDNIGHT_SKIP_SYNC_WAIT=true
# MIDNIGHT_FORCE_DEPLOY_ON_SYNC_TIMEOUT=true
