{
  "name": "selective-reality",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm run start -w server",
    "midnight:up": "node scripts/midnight-docker.mjs up",
    "midnight:down": "node scripts/midnight-docker.mjs down",
    "midnight:logs": "node scripts/midnight-docker.mjs logs",
    "check:midnight": "node scripts/check-midnight-env.mjs",
    "compile:contract": "node scripts/compile-contract.mjs",
    "deploy:midnight": "npm run deploy:midnight -w server"
  },
  "engines": {
    "node": ">=22 <24"
  },
  "overrides": {
    "@midnight-ntwrk/ledger-v8": "8.1.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
